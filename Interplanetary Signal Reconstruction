#include <iostream>
#include <vector>
#include <algorithm>

using namespace std;

int main() {
    // Fast I/O for performance
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);

    int n;
    if (!(cin >> n)) return 0;

    vector<long long> score(n);
    for (int i = 0; i < n; ++i) {
        cin >> score[i];
    }

    // Vector to store the smallest tail of all increasing subsequences
    vector<long long> tails;

    for (int i = 0; i < n; ++i) {
        // Find the first element in 'tails' that is >= score[i]
        auto it = lower_bound(tails.begin(), tails.end(), score[i]);
        
        // If score[i] is greater than all elements, extend the subsequence
        if (it == tails.end()) {
            tails.push_back(score[i]);
        } 
        // Otherwise, replace the element to keep the tail as small as possible
        else {
            *it = score[i];
        }
    }

    // The length of the longest increasing subsequence is the size of the tails array
    cout << tails.size() << "\n";

    return 0;
}
